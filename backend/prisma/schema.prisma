generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SaaS multi-tenancy: Organization is the tenant
// ============================================
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Plan & limits (denormalized from plan code for cheap reads)
  plan         String   @default("FREE") // FREE, PRO, BUSINESS
  maxUsers     Int      @default(3)
  maxOrders    Int      @default(500)   // per calendar month
  maxProducts  Int      @default(50)

  // Stripe-ready subscription fields (null until paid)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  subscriptionStatus   String?  // active, trialing, past_due, canceled, unpaid
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  // Branding
  logo         String?  // data URL (base64) or external URL, max ~200KB after client-side resize
  primaryColor String?  // hex e.g. "#3b82f6"; null = default blue

  users           User[]
  customers       Customer[]
  products        Product[]
  orders          Order[]
  expenses        Expense[]
  activityLogs    ActivityLog[]
  notifications   Notification[]
  integrations    Integration[]
  webhookTokens   WebhookToken[]
  callbacks       Callback[]
  ccPayments      CcPayment[]
  passwordResets  PasswordReset[]
  emailVerifications EmailVerification[]
  orderTemplates  OrderTemplate[]
  achievements    Achievement[]
  salesGoals      SalesGoal[]
  orderViews      OrderView[]

  @@map("organizations")
}

model SalesGoal {
  id             String   @id @default(cuid())
  organizationId String
  period         String   // MONTH, QUARTER, YEAR
  startDate      DateTime
  endDate        DateTime
  targetRevenue  Float    @default(0)
  targetOrders   Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, active])
  @@map("sales_goals")
}

model OrderView {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  // null = shared across the org
  name           String
  filters        String   // JSON of filter params: status, managerId, source, dateFrom, dateTo, search
  icon           String?  // optional emoji or lucide name
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("order_views")
}

model Achievement {
  id             String   @id @default(cuid())
  organizationId String
  code           String   // e.g. 'delivered_100', 'revenue_1m'
  title          String
  description    String?
  icon           String?  // lucide icon name
  achievedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("achievements")
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  password       String
  role           String   @default("MANAGER") // ADMIN, MANAGER, VIEWER, CALL_CENTER
  avatar         String?
  active         Boolean  @default(true)
  emailVerified  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders        Order[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  callbacks     Callback[]
  ccPayments    CcPayment[]

  @@index([organizationId])
  @@map("users")
}

model Customer {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  phone           String
  email           String?
  address         String?
  city            String?
  notes           String?
  isBlacklisted   Boolean  @default(false)
  blacklistReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("customers")
}

model Product {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  sku                String?
  description        String?
  purchasePrice      Float    @default(0)
  salePrice          Float    @default(0)
  stock              Int      @default(0)
  lowStockThreshold  Int      @default(5)
  image              String?  @db.Text
  active             Boolean  @default(true)
  lowStockNotifiedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@map("products")
}

model Order {
  id              String   @id @default(cuid())
  organizationId  String
  orderNum        Int      @default(0)
  customerId      String
  managerId       String?
  status          String   @default("NEW")
  source          String   @default("MANUAL")
  comment         String?
  total           Float    @default(0)
  deliveryService String?
  deliveryCity    String?
  deliveryAddress String?
  recipientName   String?
  npCityRef       String?
  npWarehouseRef  String?
  trackingNumber  String?
  cancelReason    String?

  // Attribution для AdTrack (приходит из Magaz/лендинга с заказом)
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  fbclid            String?
  ttclid            String?
  gclid             String?
  customerIp        String?
  customerUserAgent String?

  // Маркеры доставки в AdTrack для дедупликации/идемпотентности
  adtrackLastStatus    String?
  adtrackLastSentAt    DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer       @relation(fields: [customerId], references: [id])
  manager      User?          @relation(fields: [managerId], references: [id])
  items        OrderItem[]
  history      OrderHistory[]
  callbacks    Callback[]

  @@unique([organizationId, orderNum])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  name      String
  quantity  Int     @default(1)
  price     Float   @default(0)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderHistory {
  id        String   @id @default(cuid())
  orderId   String
  userId    String?
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_history")
}

model Expense {
  id             String   @id @default(cuid())
  organizationId String
  category       String
  amount         Float
  description    String?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, date])
  @@map("expenses")
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  details        String?
  ip             String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@map("activity_logs")
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  type           String
  title          String
  message        String
  read           Boolean  @default(false)
  entityId       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId, read])
  @@map("notifications")
}

model Integration {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  name           String
  config         String   @default("{}")
  active         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
  @@map("integrations")
}

model WebhookToken {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  token          String   @unique
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("webhook_tokens")
}

model Callback {
  id             String    @id @default(cuid())
  organizationId String
  orderId        String
  managerId      String?
  scheduledAt    DateTime
  note           String?
  done           Boolean   @default(false)
  doneAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  manager      User?        @relation(fields: [managerId], references: [id])

  @@index([organizationId])
  @@map("callbacks")
}

model CcPayment {
  id             String   @id @default(cuid())
  organizationId String
  operatorId     String
  amount         Float
  note           String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operator     User         @relation(fields: [operatorId], references: [id])

  @@index([organizationId])
  @@map("cc_payments")
}

// ============================================
// Auth flows: email verification & password reset
// ============================================
model EmailVerification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  token          String   @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

// Order template — reusable preset for fast order creation (e.g. "kit of 3 items")
model OrderTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  items          String   // JSON-serialized array of { productId?, name, quantity, price }
  source         String?  // optional default source
  comment        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("order_templates")
}

model PasswordReset {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  token          String   @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}
