# --- Local development (SQLite) ---
# DATABASE_URL="file:./dev.db"

# --- Production / Docker (PostgreSQL) ---
DATABASE_URL="postgresql://crmuser:yourpassword@localhost:5432/crmdb"

JWT_SECRET="change-this-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Nova Poshta API key (optional)
NP_API_KEY=""

# TurboSMS (optional)
TURBOSMS_TOKEN=""

# Frontend URL (for webhooks/CORS)
FRONTEND_URL="http://localhost:3000"
