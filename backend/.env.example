# --- Database ---
DATABASE_URL="postgresql://crmuser:yourpassword@localhost:5432/crmdb"

# --- Auth ---
JWT_SECRET="generate-a-strong-random-string-of-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=3001
NODE_ENV=production
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# --- Frontend URL (for emails, redirects) ---
FRONTEND_URL="http://localhost:3000"

# --- Email (transactional) ---
# Configure either Resend or SendGrid. Without keys, emails log to console.
RESEND_API_KEY=""
# SENDGRID_API_KEY=""
MAIL_FROM="CRM Pro <noreply@yourdomain.com>"

# --- Stripe (optional, for billing) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# --- Optional integrations (used as fallback for default org) ---
TELEGRAM_BOT_TOKEN=""
NP_API_KEY=""
TURBOSMS_TOKEN=""

# --- Background jobs ---
NP_TRACKER_CRON="0 */3 * * *"
SLA_NEW_ORDER_HOURS=2
SLA_CHECK_INTERVAL_CRON="*/30 * * * *"
# On serverless (Vercel) node-cron does not run. Drive workers via an external
# scheduler hitting GET/POST /api/cron/:job (np|sla|callbacks|lowstock|all)
# with header `Authorization: Bearer <CRON_SECRET>`. Leave unset to disable
# the endpoint (it returns 503 when CRON_SECRET is not configured).
CRON_SECRET=""

# --- Optional: bootstrap initial admin if default-org is empty ---
# BOOTSTRAP_ADMIN_EMAIL=""
# BOOTSTRAP_ADMIN_PASSWORD=""

# --- Optional rashod webhook (analytics integration) ---
RASHOD_WEBHOOK_URL=""
RASHOD_WEBHOOK_TOKEN=""

# --- Optional AdTrack integration (per-org конфиг хранится в Integration{type:'ADTRACK'}) ---
# Опциональная глобальная подмена базового URL. Если не задана, юзер сам ставит
# baseUrl в Settings → Integrations (default: https://adtrack-backend.vercel.app).
ADTRACK_WEBHOOK_URL=""
