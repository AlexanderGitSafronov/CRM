# --- Database ---
DATABASE_URL="postgresql://crmuser:yourpassword@localhost:5432/crmdb"

# --- Auth ---
JWT_SECRET="generate-a-strong-random-string-of-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=3001
NODE_ENV=production
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# --- Frontend URL (for emails, redirects) ---
FRONTEND_URL="http://localhost:3000"

# --- Email (transactional) ---
# Configure either Resend or SendGrid. Without keys, emails log to console.
RESEND_API_KEY=""
# SENDGRID_API_KEY=""
MAIL_FROM="CRM Pro <noreply@yourdomain.com>"

# --- Stripe (optional, for billing) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# --- Optional integrations (used as fallback for default org) ---
TELEGRAM_BOT_TOKEN=""
NP_API_KEY=""
TURBOSMS_TOKEN=""

# --- Background jobs ---
NP_TRACKER_CRON="0 */3 * * *"
SLA_NEW_ORDER_HOURS=2
SLA_CHECK_INTERVAL_CRON="*/30 * * * *"

# --- Optional: bootstrap initial admin if default-org is empty ---
# BOOTSTRAP_ADMIN_EMAIL=""
# BOOTSTRAP_ADMIN_PASSWORD=""

# --- Optional rashod webhook (analytics integration) ---
RASHOD_WEBHOOK_URL=""
RASHOD_WEBHOOK_TOKEN=""
